        function openUpgrade(index) {
            game.selectedItem = index;
            const item = game.player.inventory[index];
            const currentUpgradeLevel = item.upgradeLevel || 0;
            const cost = (currentUpgradeLevel + 1) * 3;
            
            let displayName = `（${item.equipLevel}级）${item.name}`;
            if (currentUpgradeLevel > 0) {
                displayName += `+${currentUpgradeLevel}`;
            }
            
            ui.upgradeItemInfo.innerHTML = `
                <div class="rarity-${item.rarity}" style="font-weight: bold;">${displayName}</div>
            `;
            ui.upgradeCost.textContent = `消耗: ${cost} 强化石 (当前: ${game.player.stones})`;
            ui.upgradeSection.classList.remove('hidden');
        }

        function openUpgradeFromDetail() {
            const slot = game.selectedSlot;
            const item = game.player.equipped[slot];
            
            if (!item) return;
            
            // 从装备栏移除并放入背包
            game.player.equipped[slot] = null;
            game.player.inventory.push(item);
            const index = game.player.inventory.length - 1;
            
            closeEquipDetail();
            showEquipModal();
            openUpgrade(index);
            
            // 记住这是从装备栏过来的，强化后自动装回去
            game.upgradeFromEquip = slot;
        }

        function closeUpgrade() {
            ui.upgradeSection.classList.add('hidden');
        }

        function upgradeItem() {
            const index = game.selectedItem;
            const item = game.player.inventory[index];
            const currentUpgradeLevel = item.upgradeLevel || 0;
            
            if (currentUpgradeLevel >= 20) {
                log('❌ 装备已达到最高强化等级（20级）！', 'damage');
                return;
            }
            
            const cost = (currentUpgradeLevel + 1) * 3;
            
            if (game.player.stones < cost) {
                log('💎 强化石不足！', 'damage');
                return;
            }
            
            let successRate = 100;
            if (currentUpgradeLevel >= 3) {
                if (currentUpgradeLevel < 10) {
                    successRate = 100 - (currentUpgradeLevel - 2) * 11.4;
                } else if (currentUpgradeLevel === 10) {
                    successRate = 20;
                } else {
                    successRate = Math.max(0.5, 20 - (currentUpgradeLevel - 10) * 2.17);
                }
            }
            successRate = Math.max(0.5, Math.min(100, successRate));
            
            const isSuccess = Math.random() * 100 < successRate;
            game.player.stones -= cost;
            
            let displayName = `（${item.equipLevel}级）${item.name}`;
            
            if (isSuccess) {
                item.upgradeLevel = currentUpgradeLevel + 1;
                if (item.upgradeLevel > 0) {
                    displayName += `+${item.upgradeLevel}`;
                }
                log(`✨ ${displayName} 强化成功！（成功率${successRate.toFixed(1)}%）`, 'loot');
            } else {
                if (currentUpgradeLevel > 0) {
                    displayName += `+${currentUpgradeLevel}`;
                }
                log(`💥 ${displayName} 强化失败！（成功率${successRate.toFixed(1)}%）`, 'damage');
            }
            
            if (game.upgradeFromEquip) {
                const slot = game.upgradeFromEquip;
                if (game.player.equipped[slot]) {
                    game.player.inventory.push(game.player.equipped[slot]);
                }
                game.player.equipped[slot] = item;
                game.player.inventory.splice(index, 1);
                game.upgradeFromEquip = null;
            }
            
            calculatePlayerStats();
            closeUpgrade();
            showEquipModal();
        }

        function decomposeItem() {
            const slot = game.selectedSlot;
            const item = game.player.equipped[slot];
            
            if (!item) return;
            
            const stones = getDecomposeValue(item);
            game.player.stones += stones;
            game.player.equipped[slot] = null;
            
            log(`🔧 分解 ${item.name}，获得 ${stones} 个强化石`, 'loot');
            calculatePlayerStats();
            closeEquipDetail();
        }

        function decomposeItemFromBag(index) {
            const item = game.player.inventory[index];
            const stones = getDecomposeValue(item);
            game.player.stones += stones;
            game.player.inventory.splice(index, 1);
            
            log(`🔧 分解 ${item.name}，获得 ${stones} 个强化石`, 'loot');
            calculatePlayerStats();
            showBag();
        }

        function getDecomposeValue(item) {
            const rarityMultiplier = { common: 1, rare: 2, epic: 4, legendary: 8, mythic: 15 };
            return Math.floor(rarityMultiplier[item.rarity] * (item.equipLevel || 1) * 2);
        }

        function openShop() {
            ui.shopList.innerHTML = '';
            
            const shopItems = [];
            for (let i = 0; i < 6; i++) {
                shopItems.push(generateEquipment());
            }
            
            shopItems.forEach((item, index) => {
                const price = getShopPrice(item);
                const div = document.createElement('div');
                div.className = 'shop-item';
                
                let displayName = `（${item.equipLevel}级）${item.name}`;
                if (item.upgradeLevel > 0) {
                    displayName += `+${item.upgradeLevel}`;
                }
                
                div.innerHTML = `
                    <div style="flex: 1;">
                        <div class="rarity-${item.rarity}" style="font-weight: bold;">${displayName}</div>
                        <div style="margin-top: 5px; font-size: 0.85rem;">${getAffixDisplay(item)}</div>
                    </div>
                    <button class="btn btn-primary" onclick="buyItem(${index})" style="padding: 8px 16px;">
                        💎 ${price}
                    </button>
                `;
                div.dataset.item = JSON.stringify(item);
                div.dataset.price = price;
                ui.shopList.appendChild(div);
            });
            
            ui.shopModal.classList.remove('hidden');
        }

        function closeShop() {
            ui.shopModal.classList.add('hidden');
        }

        // 铁匠铺功能
        function openBlacksmith() {
            ui.blacksmithStones.textContent = game.player.stones;
            selectedUpgradeItem = null;
            selectedUpgradeSlot = null;
            renderBlacksmithEquipList();
            ui.blacksmithUpgradeArea.classList.add('hidden');
            ui.blacksmithNoSelection.classList.remove('hidden');
            ui.blacksmithModal.classList.remove('hidden');
        }

        function closeBlacksmith() {
            ui.blacksmithModal.classList.add('hidden');
            selectedUpgradeItem = null;
            selectedUpgradeSlot = null;
        }

        function renderBlacksmithEquipList() {
            ui.blacksmithEquipList.innerHTML = '';
            
            const slots = ['weapon', 'helmet', 'armor', 'legs', 'boots', 'ring', 'necklace'];
            const icons = { weapon: '⚔️', helmet: '👑', armor: '🛡️', legs: '👖', boots: '👢', ring: '💍', necklace: '📿' };
            const names = { weapon: '武器', helmet: '头盔', armor: '衣服', legs: '护腿', boots: '靴子', ring: '戒指', necklace: '项链' };
            
            let hasEquip = false;
            
            slots.forEach(slot => {
                const item = game.player.equipped[slot];
                if (item) {
                    hasEquip = true;
                    const div = document.createElement('div');
                    div.className = 'item-row';
                    div.style.cursor = 'pointer';
                    
                    let displayName = `${icons[slot]} ${names[slot]}: （${item.equipLevel}级）${item.name}`;
                    if (item.upgradeLevel > 0) {
                        displayName += `+${item.upgradeLevel}`;
                    }
                    
                    const currentUpgradeLevel = item.upgradeLevel || 0;
                    const isMaxLevel = currentUpgradeLevel >= 20;
                    
                    div.innerHTML = `
                        <div style="flex: 1;">
                            <div class="rarity-${item.rarity}" style="font-weight: bold;">${displayName}</div>
                            <div style="font-size: 0.8rem; color: #9ca3af; margin-top: 3px;">
                                ${isMaxLevel ? '<span style="color: #e53e3e;">已满级</span>' : `强化等级: +${currentUpgradeLevel}`}
                            </div>
                        </div>
                        <div style="color: #9ca3af; font-size: 0.8rem;">
                            ${isMaxLevel ? '' : `💎 ${(currentUpgradeLevel + 1) * 3}`}
                        </div>
                    `;
                    
                    div.onclick = () => selectUpgradeItem(slot);
                    ui.blacksmithEquipList.appendChild(div);
                }
            });
            
            if (!hasEquip) {
                ui.blacksmithEquipList.innerHTML = '<div style="color: #9ca3af; text-align: center;">没有已装备的装备</div>';
            }
        }

        function selectUpgradeItem(slot) {
            selectedUpgradeSlot = slot;
            selectedUpgradeItem = game.player.equipped[slot];
            
            if (!selectedUpgradeItem) return;
            
            const currentUpgradeLevel = selectedUpgradeItem.upgradeLevel || 0;
            
            if (currentUpgradeLevel >= 20) {
                log('❌ 该装备已达到最高强化等级', 'damage');
                return;
            }
            
            ui.blacksmithNoSelection.classList.add('hidden');
            ui.blacksmithUpgradeArea.classList.remove('hidden');
            
            updateUpgradeDisplay();
        }

        function updateUpgradeDisplay() {
            if (!selectedUpgradeItem) return;
            
            const item = selectedUpgradeItem;
            const currentUpgradeLevel = item.upgradeLevel || 0;
            const nextUpgradeLevel = currentUpgradeLevel + 1;
            const cost = nextUpgradeLevel * gameConfig.upgrade.costMultiplier;
            
            // 计算成功率
            let successRate = 100;
            if (currentUpgradeLevel >= 3) {
                if (currentUpgradeLevel < 10) {
                    successRate = 100 - (currentUpgradeLevel - 2) * 11.4;
                } else if (currentUpgradeLevel === 10) {
                    successRate = 20;
                } else {
                    successRate = Math.max(0.5, 20 - (currentUpgradeLevel - 10) * 2.17);
                }
            }
            successRate = Math.max(0.5, Math.min(100, successRate));
            
            // 更新成功率显示
            ui.upgradeSuccessRate.textContent = successRate.toFixed(1) + '%';
            ui.upgradeSuccessRate.className = 'success-rate ' + 
                (successRate >= 50 ? 'rate-high' : successRate >= 20 ? 'rate-medium' : 'rate-low');
            
            ui.blacksmithUpgradeCost.textContent = cost;
            ui.upgradeNextLevel.textContent = nextUpgradeLevel;
            
            // 计算属性
            const equipLevelMultiplier = Math.pow(gameConfig.equip.levelMultiplier, (item.equipLevel || 1) - 1);
            
            // 当前强化倍率
            let currentBonus = 0;
            for (let i = 1; i <= currentUpgradeLevel; i++) {
                currentBonus += i;
            }
            const currentMultiplier = 1 + currentBonus / 100;
            
            // 下一级强化倍率
            let nextBonus = currentBonus + nextUpgradeLevel;
            const nextMultiplier = 1 + nextBonus / 100;
            
            // 显示名称
            let currentDisplayName = `（${item.equipLevel}级）${item.name}`;
            if (currentUpgradeLevel > 0) {
                currentDisplayName += `+${currentUpgradeLevel}`;
            }
            
            let nextDisplayName = `（${item.equipLevel}级）${item.name}+${nextUpgradeLevel}`;
            
            // 当前属性
            const currentAtk = Math.floor((item.baseAtk || 0) * equipLevelMultiplier * currentMultiplier);
            const currentDef = Math.floor((item.baseDef || 0) * equipLevelMultiplier * currentMultiplier);
            const currentHp = Math.floor((item.baseHp || 0) * equipLevelMultiplier * currentMultiplier);
            
            // 下一级属性
            const nextAtk = Math.floor((item.baseAtk || 0) * equipLevelMultiplier * nextMultiplier);
            const nextDef = Math.floor((item.baseDef || 0) * equipLevelMultiplier * nextMultiplier);
            const nextHp = Math.floor((item.baseHp || 0) * equipLevelMultiplier * nextMultiplier);
            
            // 渲染当前属性
            let currentHtml = `<div style="font-weight: bold; margin-bottom: 8px;" class="rarity-${item.rarity}">${currentDisplayName}</div>`;
            if (currentAtk > 0) currentHtml += `<div>⚔️ 攻击: ${currentAtk}</div>`;
            if (currentDef > 0) currentHtml += `<div>🛡️ 防御: ${currentDef}</div>`;
            if (currentHp > 0) currentHtml += `<div>❤️ 生命: ${currentHp}</div>`;
            
            // 渲染下一级属性
            let nextHtml = `<div style="font-weight: bold; margin-bottom: 8px;" class="rarity-${item.rarity}">${nextDisplayName}</div>`;
            if (nextAtk > 0) {
                const diff = nextAtk - currentAtk;
                nextHtml += `<div>⚔️ 攻击: ${nextAtk} <span style="color: #48bb78;">(+${diff})</span></div>`;
            }
            if (nextDef > 0) {
                const diff = nextDef - currentDef;
                nextHtml += `<div>🛡️ 防御: ${nextDef} <span style="color: #48bb78;">(+${diff})</span></div>`;
            }
            if (nextHp > 0) {
                const diff = nextHp - currentHp;
                nextHtml += `<div>❤️ 生命: ${nextHp} <span style="color: #48bb78;">(+${diff})</span></div>`;
            }
            
            ui.upgradeCurrentInfo.innerHTML = currentHtml;
            ui.upgradeNextInfo.innerHTML = nextHtml;
        }

        function doUpgrade() {
            if (!selectedUpgradeItem || selectedUpgradeSlot === null) return;
            
            const item = selectedUpgradeItem;
            const currentUpgradeLevel = item.upgradeLevel || 0;
            
            if (currentUpgradeLevel >= 20) {
                log('❌ 装备已达到最高强化等级（20级）！', 'damage');
                return;
            }
            
            const cost = (currentUpgradeLevel + 1) * gameConfig.upgrade.costMultiplier;
            
            if (game.player.stones < cost) {
                log('💎 强化石不足！', 'damage');
                return;
            }
            
            // 计算成功率
            let successRate = 100;
            if (currentUpgradeLevel >= 3) {
                if (currentUpgradeLevel < 10) {
                    successRate = 100 - (currentUpgradeLevel - 2) * 11.4;
                } else if (currentUpgradeLevel === 10) {
                    successRate = 20;
                } else {
                    successRate = Math.max(0.5, 20 - (currentUpgradeLevel - 10) * 2.17);
                }
            }
            successRate = Math.max(0.5, Math.min(100, successRate));
            
            const isSuccess = Math.random() * 100 < successRate;
            game.player.stones -= cost;
            
            let displayName = `（${item.equipLevel}级）${item.name}`;
            
            if (isSuccess) {
                item.upgradeLevel = currentUpgradeLevel + 1;
                if (item.upgradeLevel > 0) {
                    displayName += `+${item.upgradeLevel}`;
                }
                log(`✨ ${displayName} 强化成功！（成功率${successRate.toFixed(1)}%）`, 'loot');
            } else {
                if (currentUpgradeLevel > 0) {
                    displayName += `+${currentUpgradeLevel}`;
                }
                log(`💥 ${displayName} 强化失败！（成功率${successRate.toFixed(1)}%）`, 'damage');
            }
            
            calculatePlayerStats();
            ui.blacksmithStones.textContent = game.player.stones;
            
            // 刷新显示，保持弹窗打开
            renderBlacksmithEquipList();
            updateUI();
            
            // 如果装备还在，更新显示
            if (game.player.equipped[selectedUpgradeSlot] === item) {
                if ((item.upgradeLevel || 0) >= 20) {
                    // 已满级，回到选择界面
                    ui.blacksmithUpgradeArea.classList.add('hidden');
                    ui.blacksmithNoSelection.classList.remove('hidden');
                    selectedUpgradeItem = null;
                    selectedUpgradeSlot = null;
                } else {
                    updateUpgradeDisplay();
                }
            } else {
                // 装备位置变了，回到选择界面
                ui.blacksmithUpgradeArea.classList.add('hidden');
                ui.blacksmithNoSelection.classList.remove('hidden');
                selectedUpgradeItem = null;
                selectedUpgradeSlot = null;
            }
        }

        function buyItem(index) {
            const divs = ui.shopList.querySelectorAll('.shop-item');
            const div = divs[index];
            const item = JSON.parse(div.dataset.item);
            const price = parseInt(div.dataset.price);
            
            if (game.player.stones < price) {
                log('💎 强化石不足！', 'damage');
                return;
            }
            
            game.player.stones -= price;
            game.player.inventory.push(item);
            log(`🏪 购买了 ${item.name}`, 'loot');
            
            div.remove();
            updateUI();
        }

        function getShopPrice(item) {
            const rarityMultiplier = { common: 5, rare: 15, epic: 40, legendary: 100, mythic: 250 };
            return rarityMultiplier[item.rarity];
        }

        function gameOver() {
            log('💀 你死了！回到本层重新开始...', 'damage');
            
            // 重置玩家状态
            game.player.hp = game.player.maxHp;
            game.player.rage = 0;
            game.state = 'idle';
            game.currentMonster = null;
            game.currentRoom = null;
            game.isDefending = false;

            // 隐藏战斗界面
            ui.monsterPanel.classList.add('hidden');
            ui.combatButtons.classList.add('hidden');
            ui.actionButtons.classList.remove('hidden');

            ui.sceneTitle.textContent = `第${game.floor}层`;
            ui.sceneDesc.textContent = '你复活了！现在可以重新探索...';
            updateUI();
        }

        document.getElementById('btn-explore').onclick = () => {
            if (game.state === 'idle') {
                showRoomSelection();
            }
        };

        document.getElementById('btn-shop').onclick = openShop;
        document.getElementById('btn-blacksmith').onclick = openBlacksmith;
        document.getElementById('btn-bag').onclick = showBag;
        document.getElementById('btn-attack').onclick = () => playerAttack(false);
        document.getElementById('btn-skill').onclick = () => playerAttack(true);
        document.getElementById('btn-defend').onclick = defend;
        document.getElementById('btn-flee').onclick = flee;

        ui.victoryModal.onclick = (e) => {
            if (e.target === ui.victoryModal) {
                closeVictoryModal();
            }
        };

        ui.bagModal.onclick = (e) => {
            if (e.target === ui.bagModal) {
                closeBag();
            }
        };

        ui.equipModal.onclick = (e) => {
            if (e.target === ui.equipModal) {
                closeEquipModal();
            }
        };

        ui.equipDetailModal.onclick = (e) => {
            if (e.target === ui.equipDetailModal) {
                closeEquipDetail();
            }
        };

        ui.shopModal.onclick = (e) => {
            if (e.target === ui.shopModal) {
                closeShop();
            }
        };

        ui.blacksmithModal.onclick = (e) => {
            if (e.target === ui.blacksmithModal) {
                closeBlacksmith();
            }
        };

        ui.devPasswordModal.onclick = (e) => {
            if (e.target === ui.devPasswordModal) {
                closeDevPassword();
            }
        };

        ui.devControlModal.onclick = (e) => {
            if (e.target === ui.devControlModal) {
                closeDevControl();
            }
        };

        // 立即播放CG
        playCG();
        calculatePlayerStats();
    </script>
</body>
</html>
