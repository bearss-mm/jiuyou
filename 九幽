        function loadGame(input) {
            const file = input.files[0];
            if (!file) return;
            
            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const saveData = JSON.parse(e.target.result);
                    
                    // 恢复游戏数据
                    if (saveData.player) {
                        game.player = saveData.player;
                    }
                    if (saveData.floor) {
                        game.floor = saveData.floor;
                    }
                    if (saveData.config) {
                        gameConfig = saveData.config;
                    }
                    
                    calculatePlayerStats();
                    updateUI();
                    log('📂 存档已加载！', 'loot');
                } catch (err) {
                    log('❌ 存档文件损坏！', 'damage');
                }
            };
            reader.readAsText(file);
            input.value = '';
        }

        function calculatePlayerStats() {
            const lvBonus = (game.player.lv - 1) * gameConfig.player.lvBonus;
            
            const base = {
                hp: gameConfig.player.baseHp + lvBonus * 5, maxHp: gameConfig.player.baseHp + lvBonus * 5,
                atk: gameConfig.player.baseAtk + lvBonus * 1.5, def: gameConfig.player.baseDef + lvBonus * 0.8,
                critRate: 0, critDmg: 150,
                dmgReduction: 0,
                fireDmg: 0, iceDmg: 0, thunderDmg: 0, shadowDmg: 0, holyDmg: 0,
                vampire: 0, dodge: 0
            };

            const slots = ['weapon', 'helmet', 'armor', 'legs', 'boots', 'ring', 'necklace'];
            slots.forEach(slot => {
                const item = game.player.equipped[slot];
                if (item) {
                    let upgradeBonus = 0;
                    for (let i = 1; i <= (item.upgradeLevel || 0); i++) {
                        upgradeBonus += i;
                    }
                    const upgradeMultiplier = 1 + upgradeBonus / 100;

                    const equipLevelMultiplier = Math.pow(gameConfig.equip.levelMultiplier, (item.equipLevel || 1) - 1);

                    base.atk += Math.floor(item.baseAtk * equipLevelMultiplier * upgradeMultiplier);
                    base.def += Math.floor(item.baseDef * equipLevelMultiplier * upgradeMultiplier);
                    base.maxHp += Math.floor(item.baseHp * equipLevelMultiplier * upgradeMultiplier);
                    base.critRate += item.critRate || 0;
                    base.critDmg += item.critDmg || 0;
                    base.dmgReduction += item.dmgReduction || 0;
                    base.fireDmg += item.fireDmg || 0;
                    base.iceDmg += item.iceDmg || 0;
                    base.thunderDmg += item.thunderDmg || 0;
                    base.shadowDmg += item.shadowDmg || 0;
                    base.holyDmg += item.holyDmg || 0;
                    base.vampire += item.vampire || 0;
                    base.dodge += item.dodge || 0;
                }
            });

            if (base.critRate > 100) {
                const overflow = base.critRate - 100;
                base.critRate = 100;
                base.critDmg += Math.floor(overflow * 0.5);
            }

            game.player.atk = Math.floor(base.atk);
            game.player.def = Math.floor(base.def);
            game.player.maxHp = Math.floor(base.maxHp);
            game.player.critRate = base.critRate;
            game.player.critDmg = base.critDmg;
            game.player.dmgReduction = base.dmgReduction;
            game.player.fireDmg = base.fireDmg;
            game.player.iceDmg = base.iceDmg;
            game.player.thunderDmg = base.thunderDmg;
            game.player.shadowDmg = base.shadowDmg;
            game.player.holyDmg = base.holyDmg;
            game.player.vampire = base.vampire;
            game.player.dodge = base.dodge;

            updateUI();
            updateSkillDisplay();
        }

        function addExp(amount) {
            const oldLv = game.player.lv;
            const oldAtk = game.player.atk;
            const oldDef = game.player.def;
            
            game.player.exp += amount;
            
            while (game.player.exp >= game.player.maxExp) {
                game.player.exp -= game.player.maxExp;
                game.player.lv++;
                game.player.maxExp = Math.floor(100 * Math.pow(1.2, game.player.lv - 1));
                game.player.hp = Math.min(game.player.maxHp, game.player.hp + 50);
            }
            
            if (game.player.lv > oldLv) {
                calculatePlayerStats();
                const atkGain = game.player.atk - oldAtk;
                const defGain = game.player.def - oldDef;
                log(`🎉 升级！等级提升到 ${game.player.lv} 级！攻击+${atkGain} 防御+${defGain}`, 'levelup');
            }
        }

