                            <button class="btn btn-warning" onclick="decomposeItemFromBag(${index})" style="padding: 5px 12px; font-size: 0.8rem;">分解</button>
                        </div>
                    `;
                    ui.bagList.appendChild(div);
                });
            }

            ui.bagModal.classList.remove('hidden');
        }

        function decomposeAllItems() {
            if (game.player.inventory.length === 0) {
                log('背包中没有装备可分解！', 'damage');
                return;
            }
            
            let totalStones = 0;
            game.player.inventory.forEach(item => {
                totalStones += getDecomposeValue(item);
            });
            
            game.player.stones += totalStones;
            game.player.inventory = [];
            log(`🗑️ 分解了所有装备，获得 ${totalStones} 强化石！`, 'loot');
            
            calculatePlayerStats();
            showBag();
        }

        function closeBag() {
            ui.bagModal.classList.add('hidden');
        }

        function equipItem(index) {
            const item = game.player.inventory[index];
            const slot = item.type;
            
            if (game.player.equipped[slot]) {
                game.player.inventory.push(game.player.equipped[slot]);
            }
            
            game.player.equipped[slot] = item;
            game.player.inventory.splice(index, 1);
            
            calculatePlayerStats();
            
            // 不自动关闭弹窗，刷新列表
            if (!ui.bagModal.classList.contains('hidden')) {
                showBag();
            }
            if (!ui.equipModal.classList.contains('hidden')) {
                showEquipModal();
            }
        }

        function unequipItem() {
