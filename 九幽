<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>九幽裂谷 - 暗黑文字冒险</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Noto Serif SC', serif;
            background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
            min-height: 100vh;
            color: #e0e0e0;
        }
        .game-container { max-width: 1600px; margin: 0 auto; padding: 20px; }
        .game-header {
            text-align: center; padding: 20px 0;
            border-bottom: 2px solid rgba(139, 92, 246, 0.3);
            margin-bottom: 20px;
        }
        .game-title {
            font-size: 2.5rem; font-weight: 700;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .panel {
            background: rgba(255,255,255,0.05);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 15px;
            border: 1px solid rgba(255,255,255,0.1);
        }
        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.95rem;
            transition: all 0.3s;
            font-family: inherit;
        }
        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(102, 126, 234, 0.4); }
        .btn-danger { background: #e53e3e; color: white; }
        .btn-success { background: #48bb78; color: white; }
        .btn-warning { background: #ed8936; color: white; }
        .btn-secondary { background: #4a5568; color: white; }
        .btn-fire { background: linear-gradient(135deg, #ff6b6b, #ee5a24); color: white; }
        .btn-ice { background: linear-gradient(135deg, #74b9ff, #0984e3); color: white; }
        .btn-thunder { background: linear-gradient(135deg, #fdcb6e, #f39c12); color: white; }
        .btn-shadow { background: linear-gradient(135deg, #a29bfe, #6c5ce7); color: white; }
        .btn-holy { background: linear-gradient(135deg, #ffeaa7, #fdcb6e); color: #1a1a2e; }
        .btn:disabled { opacity: 0.5; cursor: not-allowed; }
        .stat-bar {
            background: rgba(0,0,0,0.3);
            border-radius: 10px;
            height: 20px;
            overflow: hidden;
            margin: 5px 0;
        }
        .stat-fill {
            height: 100%;
            border-radius: 10px;
            transition: width 0.3s;
        }
        .hp-fill { background: linear-gradient(90deg, #e53e3e, #fc8181); }
        .rage-fill { background: linear-gradient(90deg, #ed8936, #f6ad55); }
        .exp-fill { background: linear-gradient(90deg, #9f7aea, #a29bfe); }
        .log-entry {
            padding: 8px 12px;
            margin: 5px 0;
            border-radius: 6px;
            animation: fadeIn 0.3s;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .room-card {
            background: rgba(255,255,255,0.08);
            border-radius: 10px;
            padding: 15px;
            cursor: pointer;
            transition: all 0.3s;
            border: 1px solid rgba(255,255,255,0.1);
        }
        .room-card:hover {
            transform: translateY(-3px);
            background: rgba(255,255,255,0.12);
            box-shadow: 0 5px 20px rgba(0,0,0,0.3);
        }
        .hidden { display: none !important; }
        .modal {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.8);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 100;
        }
        .modal-content {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            padding: 25px;
            border-radius: 15px;
            max-width: 700px;
            width: 90%;
            max-height: 85vh;
            overflow-y: auto;
            border: 1px solid rgba(139, 92, 246, 0.3);
        }
        .rarity-common { color: #a0aec0; }
        .rarity-rare { color: #4299e1; }
        .rarity-epic { color: #9f7aea; }
        .rarity-legendary { color: #f6ad55; }
        .rarity-mythic { color: #e53e3e; text-shadow: 0 0 10px rgba(229, 62, 62, 0.5); }
        .equip-slot {
            background: rgba(255,255,255,0.08);
            border: 2px solid rgba(255,255,255,0.1);
            border-radius: 10px;
            padding: 12px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
        }
        .equip-slot:hover {
            background: rgba(255,255,255,0.12);
            border-color: rgba(139, 92, 246, 0.5);
        }
        .equip-slot.empty {
            color: #6b7280;
        }
        .equip-slot.rarity-mythic {
            border-color: #e53e3e;
            box-shadow: 0 0 15px rgba(229, 62, 62, 0.3);
        }
        .item-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px;
            background: rgba(255,255,255,0.05);
            border-radius: 8px;
            margin-bottom: 8px;
        }
        .upgrade-section {
            background: rgba(255,255,255,0.05);
            border-radius: 10px;
            padding: 15px;
            margin-top: 15px;
        }
        .affix-row {
            font-size: 0.85rem;
            padding: 4px 0;
        }
        .affix-fire { color: #ff6b6b; }
        .affix-ice { color: #74b9ff; }
        .affix-thunder { color: #fdcb6e; }
        .affix-shadow { color: #a29bfe; }
        .affix-holy { color: #ffeaa7; }
        .affix-crit { color: #f6ad55; }
        .affix-damage { color: #fc8181; }
        .affix-reduction { color: #68d391; }
        .affix-vampire { color: #e84393; }
        .affix-speed { color: #00cec9; }
        .affix-dodge { color: #0984e3; }
        .skill-cooldown {
            opacity: 0.6;
        }
        .skill-ready {
            animation: pulse 1.5s infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.6; }
        }
        .stat-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 8px;
        }
        .stat-item {
            padding: 8px;
            background: rgba(255,255,255,0.05);
            border-radius: 6px;
            font-size: 0.85rem;
        }
        .shop-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px;
            background: rgba(255,255,255,0.05);
            border-radius: 8px;
            margin-bottom: 10px;
        }
        /* CG播放器样式 */
        #cg-player {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #000;
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        #cg-video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        #cg-skip-btn {
            position: absolute;
            bottom: 30px;
            right: 30px;
            padding: 12px 24px;
            background: rgba(0,0,0,0.7);
            border: 2px solid rgba(255,255,255,0.3);
            color: white;
            border-radius: 8px;
            cursor: pointer;
            font-size: 1rem;
            transition: all 0.3s;
            z-index: 1001;
        }
        #cg-skip-btn:hover {
            background: rgba(139, 92, 246, 0.8);
            border-color: rgba(139, 92, 246, 1);
        }
        /* 铁匠铺弹窗样式 */
        .blacksmith-modal .modal-content {
            max-width: 900px;
        }
        .upgrade-compare {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin: 15px 0;
        }
        .upgrade-box {
            background: rgba(0,0,0,0.3);
            border-radius: 10px;
            padding: 15px;
            border: 1px solid rgba(255,255,255,0.1);
        }
        .upgrade-box.current {
            border-color: rgba(160, 174, 192, 0.5);
        }
        .upgrade-box.next {
            border-color: rgba(72, 187, 120, 0.5);
        }
        .upgrade-arrow {
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: #48bb78;
        }
        .success-rate {
            font-size: 1.2rem;
            font-weight: bold;
            padding: 10px 20px;
            border-radius: 8px;
            display: inline-block;
            margin: 10px 0;
        }
        .rate-high { background: rgba(72, 187, 120, 0.3); color: #48bb78; }
        .rate-medium { background: rgba(246, 173, 85, 0.3); color: #f6ad55; }
        .rate-low { background: rgba(229, 62, 62, 0.3); color: #e53e3e; }
    </style>
</head>
<body>
    <!-- CSS动画CG开场 -->
    <div id="cg-player" class="hidden">
        <div id="cg-content">
            <div class="cg-title">九幽裂谷</div>
            <div class="cg-subtitle">暗黑文字冒险游戏</div>
            <div class="cg-divider"></div>
            <div class="cg-intro">
                <div class="cg-line">🎮 探索神秘的九幽裂谷</div>
                <div class="cg-line">⚔️ 挑战强大的怪物</div>
                <div class="cg-line">💎 收集稀有装备</div>
                <div class="cg-line">🔨 强化你的力量</div>
                <div class="cg-line">🏆 突破层层关卡</div>
            </div>
            <div class="cg-hint">点击任意位置开始冒险</div>
        </div>
    </div>
    
    <style>
        #cg-player {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 50%, #16213e 100%);
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }
        #cg-content {
            text-align: center;
            padding: 40px;
        }
        .cg-title {
            font-size: 4rem;
            font-weight: bold;
            background: linear-gradient(135deg, #9f7aea 0%, #667eea 50%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            opacity: 0;
            animation: fadeInUp 1s ease forwards;
            text-shadow: 0 0 30px rgba(159, 122, 234, 0.5);
        }
        .cg-subtitle {
            font-size: 1.5rem;
            color: #9ca3af;
            margin-top: 15px;
            opacity: 0;
            animation: fadeInUp 1s ease 0.5s forwards;
        }
        .cg-divider {
            width: 200px;
            height: 2px;
            background: linear-gradient(90deg, transparent, #9f7aea, transparent);
            margin: 30px auto;
            opacity: 0;
            animation: fadeIn 1s ease 1s forwards;
        }
        .cg-intro {
            margin-top: 30px;
        }
        .cg-line {
            font-size: 1.2rem;
            color: #e2e8f0;
            margin: 15px 0;
            opacity: 0;
            animation: fadeInUp 0.8s ease forwards;
        }
        .cg-line:nth-child(1) { animation-delay: 1.5s; }
        .cg-line:nth-child(2) { animation-delay: 2s; }
        .cg-line:nth-child(3) { animation-delay: 2.5s; }
        .cg-line:nth-child(4) { animation-delay: 3s; }
        .cg-line:nth-child(5) { animation-delay: 3.5s; }
        .cg-hint {
            font-size: 1rem;
            color: #9f7aea;
            margin-top: 50px;
            opacity: 0;
            animation: pulse 2s ease 4s infinite;
        }
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        @keyframes pulse {
            0%, 100% { opacity: 0.5; }
            50% { opacity: 1; }
        }
    </style>

    <!-- 开发者模式按钮 -->
    <div id="dev-mode-btn" style="position: fixed; bottom: 20px; left: 20px; z-index: 999;">
        <button class="btn btn-secondary" style="padding: 8px 12px; font-size: 0.8rem; opacity: 0.3;" onclick="openDevPassword()">⚙️ 开发者</button>
    </div>

    <div class="game-container">
        <div class="game-header">
            <h1 class="game-title">九幽裂谷</h1>
            <p style="color: #9ca3af; margin-top: 8px;">暗黑文字冒险游戏</p>
        </div>

        <div style="display: grid; grid-template-columns: 260px 1fr 260px; gap: 12px;">
            <!-- 左侧属性面板 -->
            <div>
                <div class="panel">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                        <div style="font-size: 1rem; color: #9f7aea; font-weight: bold;">👤 角色属性</div>
                    </div>
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                        <div style="font-weight: bold; font-size: 0.95rem;">🧙 <span id="player-name">冒险者</span></div>
                        <div style="color: #9f7aea; font-size: 0.9rem;">Lv.<span id="player-lv">1</span></div>
                    </div>
                    
                    <div style="margin-bottom: 8px;">
                        <div style="font-size: 0.75rem; color: #9ca3af; margin-bottom: 2px;">经验值</div>
                        <div class="stat-bar" style="height: 16px;">
                            <div class="stat-fill exp-fill" id="exp-bar" style="width: 0%;"></div>
                        </div>
                        <div style="font-size: 0.7rem; color: #9ca3af; text-align: right;">
                            <span id="player-exp">0</span> / <span id="player-maxexp">100</span>
                        </div>
                    </div>

                    <div style="margin-bottom: 8px;">
                        <div style="font-size: 0.75rem; color: #9ca3af; margin-bottom: 2px;">生命值</div>
                        <div class="stat-bar" style="height: 16px;">
                            <div class="stat-fill hp-fill" id="hp-bar" style="width: 100%;"></div>
                        </div>
                        <div style="font-size: 0.7rem; color: #9ca3af; text-align: right;">
                            <span id="player-hp">100</span> / <span id="player-maxhp">100</span>
                        </div>
                    </div>

                    <div style="margin-bottom: 12px;">
                        <div style="font-size: 0.75rem; color: #9ca3af; margin-bottom: 2px;">怒气值</div>
                        <div class="stat-bar" style="height: 16px;">
                            <div class="stat-fill rage-fill" id="rage-bar" style="width: 0%;"></div>
                        </div>
                        <div style="font-size: 0.7rem; color: #9ca3af; text-align: right;">
                            <span id="player-rage">0</span> / 100
                        </div>
                    </div>

                    <div class="stat-grid">
                        <div class="stat-item">
                            <span style="color: #fc8181;">⚔️ 攻击</span>
                            <span style="float: right; font-weight: bold;" id="player-atk">10</span>
                        </div>
                        <div class="stat-item">
                            <span>🛡️ 防御</span>
                            <span style="float: right; font-weight: bold;" id="player-def">5</span>
                        </div>
                        <div class="stat-item">
                            <span class="affix-crit">💥 暴击</span>
                            <span style="float: right;" id="player-crit">0%</span>
                        </div>
                        <div class="stat-item">
                            <span class="affix-crit">💢 暴伤</span>
                            <span style="float: right;" id="player-critDmg">150%</span>
                        </div>
                        <div class="stat-item">
                            <span class="affix-reduction">🛡️ 减伤</span>
                            <span style="float: right;" id="player-dmgReduction">0%</span>
                        </div>
                        <div class="stat-item">
                            <span class="affix-vampire">🦇 吸血</span>
                            <span style="float: right;" id="player-vampire">0%</span>
                        </div>
                        <div class="stat-item">
                            <span class="affix-dodge">🌪️ 闪避</span>
                            <span style="float: right;" id="player-dodge">0%</span>
                        </div>
                    </div>

                    <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid rgba(255,255,255,0.1);">
                        <div style="font-size: 0.85rem; color: #9f7aea; margin-bottom: 8px;">✨ 元素伤害加成</div>
                        <div class="stat-grid">
                            <div class="stat-item">
                                <span class="affix-fire">🔥 火焰</span>
                                <span style="float: right;" id="player-fireDmg">0%</span>
                            </div>
                            <div class="stat-item">
                                <span class="affix-ice">❄️ 冰霜</span>
                                <span style="float: right;" id="player-iceDmg">0%</span>
                            </div>
                            <div class="stat-item">
                                <span class="affix-thunder">⚡ 雷电</span>
                                <span style="float: right;" id="player-thunderDmg">0%</span>
                            </div>
                            <div class="stat-item">
                                <span class="affix-shadow">🌑 暗影</span>
                                <span style="float: right;" id="player-shadowDmg">0%</span>
                            </div>
                            <div class="stat-item">
                                <span class="affix-holy">✨ 神圣</span>
                                <span style="float: right;" id="player-holyDmg">0%</span>
                            </div>
                        </div>
                    </div>

                    <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid rgba(255,255,255,0.1);">
                        <div style="color: #f6e05e; font-size: 0.9rem;">💎 强化石: <span id="player-stones">0</span></div>
                    </div>
                    
                    <div style="margin-top: 12px; display: flex; gap: 8px; flex-wrap: wrap;">
                        <button class="btn btn-primary" onclick="saveGame()" style="padding: 6px 12px; font-size: 0.8rem; flex: 1;">💾 保存</button>
                        <button class="btn btn-success" onclick="document.getElementById('load-file-input').click()" style="padding: 6px 12px; font-size: 0.8rem; flex: 1;">📂 读取</button>
                        <input type="file" id="load-file-input" accept=".json" style="display: none;" onchange="loadGame(this)">
                    </div>
                </div>
            </div>

            <!-- 中间主区域 -->
            <div>
                <div class="panel">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                        <div style="font-size: 1rem; color: #9f7aea; font-weight: bold;" id="scene-title">🏰 九幽裂谷入口</div>
                        <div style="font-size: 0.9rem; color: #9f7aea;">第 <span id="current-floor">1</span> 层</div>
                    </div>
                    <div id="scene-desc" style="line-height: 1.7; color: #d1d5db; font-size: 0.9rem;">
                        你站在九幽裂谷的入口处，黑暗的深渊在你面前张开巨口。传说这里埋藏着无尽的宝藏，但也充满了致命的危险...
                    </div>
                </div>

                <!-- 装备栏横放 -->
                <div class="panel">
                    <div style="font-size: 0.9rem; color: #9f7aea; margin-bottom: 10px; font-weight: bold;">🛡️ 装备栏</div>
                    <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px;">
                        <div class="equip-slot empty" id="slot-weapon" onclick="showEquipDetail('weapon')" style="padding: 8px;">
                            <div style="font-size: 1.1rem;">⚔️</div>
                            <div style="font-size: 0.65rem; margin-top: 2px;">武器</div>
                            <div class="equip-name" style="font-size: 0.55rem; color: #9ca3af;">未装备</div>
                        </div>
                        <div class="equip-slot empty" id="slot-helmet" onclick="showEquipDetail('helmet')" style="padding: 8px;">
                            <div style="font-size: 1.1rem;">🪖</div>
                            <div style="font-size: 0.65rem; margin-top: 2px;">头盔</div>
                            <div class="equip-name" style="font-size: 0.55rem; color: #9ca3af;">未装备</div>
                        </div>
                        <div class="equip-slot empty" id="slot-armor" onclick="showEquipDetail('armor')" style="padding: 8px;">
                            <div style="font-size: 1.1rem;">🛡️</div>
                            <div style="font-size: 0.65rem; margin-top: 2px;">衣服</div>
                            <div class="equip-name" style="font-size: 0.55rem; color: #9ca3af;">未装备</div>
                        </div>
                        <div class="equip-slot empty" id="slot-legs" onclick="showEquipDetail('legs')" style="padding: 8px;">
                            <div style="font-size: 1.1rem;">👖</div>
                            <div style="font-size: 0.65rem; margin-top: 2px;">护腿</div>
                            <div class="equip-name" style="font-size: 0.55rem; color: #9ca3af;">未装备</div>
                        </div>
                        <div class="equip-slot empty" id="slot-boots" onclick="showEquipDetail('boots')" style="padding: 8px;">
                            <div style="font-size: 1.1rem;">🥾</div>
                            <div style="font-size: 0.65rem; margin-top: 2px;">靴子</div>
                            <div class="equip-name" style="font-size: 0.55rem; color: #9ca3af;">未装备</div>
                        </div>
                        <div class="equip-slot empty" id="slot-ring" onclick="showEquipDetail('ring')" style="padding: 8px;">
                            <div style="font-size: 1.1rem;">💍</div>
                            <div style="font-size: 0.65rem; margin-top: 2px;">戒指</div>
                            <div class="equip-name" style="font-size: 0.55rem; color: #9ca3af;">未装备</div>
                        </div>
                        <div class="equip-slot empty" id="slot-necklace" onclick="showEquipDetail('necklace')" style="padding: 8px;">
                            <div style="font-size: 1.1rem;">📿</div>
                            <div style="font-size: 0.65rem; margin-top: 2px;">项链</div>
