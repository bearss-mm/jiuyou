        function playerAttack(isSkill) {
            if (game.state !== 'combat') return;

            const m = game.currentMonster;
            const weapon = game.player.equipped.weapon;
            
            // 基础攻击伤害计算
            let baseDmg = Math.max(1, game.player.atk - m.def + randomInt(-3, 5));
            let isCrit = Math.random() * 100 < game.player.critRate;
            
            // 元素伤害加成（只有对应武器类型才生效）
            let elementBonus = 0;
            let elementType = '';
            
            if (weapon && weapon.element) {
                elementType = weapon.element;
                // 根据武器类型获取对应的元素伤害加成百分比
                let elementPercent = 0;
                if (elementType === 'fire') elementPercent = game.player.fireDmg;
                else if (elementType === 'ice') elementPercent = game.player.iceDmg;
                else if (elementType === 'thunder') elementPercent = game.player.thunderDmg;
                else if (elementType === 'shadow') elementPercent = game.player.shadowDmg;
                else if (elementType === 'holy') elementPercent = game.player.holyDmg;
                
                // 元素伤害 = 基础攻击 * 元素加成百分比
                elementBonus = Math.floor(baseDmg * elementPercent / 100);
            }
            
            // 总伤害
            let totalDmg = baseDmg + elementBonus;
            
            // 应用暴击
            if (isCrit) {
                totalDmg = Math.floor(totalDmg * game.player.critDmg / 100);
            }
            
            // 应用怪物伤害减免
            let actualDmg = totalDmg;
            if (m.dmgReduction > 0) {
                actualDmg = Math.floor(totalDmg * (100 - m.dmgReduction) / 100);
            }
            
            if (isSkill) {
                if (game.player.rage < 100) {
                    log('怒气不足！无法释放技能', 'damage');
                    return;
                }
                
                game.player.rage -= 100;
                
                if (weapon && weapon.skill) {
                    const skill = skillTypes[weapon.skill];
                    // 技能伤害 = 总伤害 * 技能倍率
                    let skillDmg = Math.floor(totalDmg * skill.multiplier);
                    
                    // 再次应用怪物伤害减免
                    if (m.dmgReduction > 0) {
                        actualDmg = Math.floor(skillDmg * (100 - m.dmgReduction) / 100);
                    } else {
                        actualDmg = skillDmg;
                    }
                    
                    // 构建详细伤害日志
                    let dmgDetail = buildDamageLog(baseDmg, elementBonus, elementType, isCrit, game.player.critDmg, m.dmgReduction, actualDmg);
                    log(`⚡ ${skill.name}！${dmgDetail}`, 'skill');
                } else {
                    let skillDmg = Math.floor(totalDmg * 1.5);
                    if (m.dmgReduction > 0) {
                        actualDmg = Math.floor(skillDmg * (100 - m.dmgReduction) / 100);
                    } else {
                        actualDmg = skillDmg;
                    }
                    let dmgDetail = buildDamageLog(baseDmg, elementBonus, elementType, isCrit, game.player.critDmg, m.dmgReduction, actualDmg);
                    log(`⚡ 释放技能！${dmgDetail}`, 'skill');
                }
            } else {
                // 普通攻击
                let dmgDetail = buildDamageLog(baseDmg, elementBonus, elementType, isCrit, game.player.critDmg, m.dmgReduction, actualDmg);
                
                if (isCrit) {
                    log(`💥 暴击！${dmgDetail}`, 'damage');
                } else {
                    log(`⚔️ 普通攻击！${dmgDetail}`, 'damage');
                }
            }

            m.hp -= actualDmg;
            
            game.player.rage = Math.min(game.player.maxRage, game.player.rage + randomInt(15, 25));
            
            if (game.player.vampire > 0) {
                const heal = Math.floor(actualDmg * game.player.vampire / 100);
                if (heal > 0) {
                    game.player.hp = Math.min(game.player.maxHp, game.player.hp + heal);
                    log(`🦇 吸血恢复了 ${heal} 点生命！`, 'heal');
                }
            }

            updateMonsterUI();
            updateUI();

            if (m.hp <= 0) {
                winCombat();
            } else {
                setTimeout(monsterAttack, 500);
            }
        }
        
        function buildDamageLog(baseDmg, elementBonus, elementType, isCrit, critDmg, monsterReduction, finalDmg) {
            const elementNames = { fire: '🔥火焰', ice: '❄️冰霜', thunder: '⚡雷电', shadow: '🌑暗影', holy: '✨神圣' };
            let log = '';
            
            // 基础伤害
            log += `造成 ${baseDmg}点`;
            
            // 元素伤害
            if (elementBonus > 0 && elementType) {
                log += ` + ${elementBonus}点${elementNames[elementType]}`;
            }
            
            // 暴击
            if (isCrit) {
                log += ` (暴击x${(critDmg/100).toFixed(1)})`;
            }
            
            // 怪物减伤
            if (monsterReduction > 0) {
                log += ` - 敌人${monsterReduction}%减伤`;
            }
            
            // 最终伤害
            log += ` = ${finalDmg}点伤害`;
            
            return log;
        }

        function defend() {
            game.isDefending = true;
            log('🛡️ 你进入防御姿态，受到的伤害减少！', 'normal');
            game.player.rage = Math.min(game.player.maxRage, game.player.rage + randomInt(20, 30));
            updateUI();
            setTimeout(() => monsterAttack(true), 500);
        }

        function flee() {
            const hpLoss = Math.floor(game.player.hp * 0.3);
            game.player.hp = Math.max(1, game.player.hp - hpLoss);
            log(`🏃 逃跑成功！扣除当前30%血量（-${hpLoss}）`, 'heal');
            updateUI();
            endCombat();
        }

        function monsterAttack(isDefending = false) {
            if (game.state !== 'combat') return;

            const m = game.currentMonster;
            
            if (Math.random() * 100 < game.player.dodge) {
                log(`🌪️ 你闪避了 ${m.name} 的攻击！`, 'heal');
                game.isDefending = false;
                return;
            }
            
            let dmg = Math.max(1, m.atk - game.player.def + randomInt(-2, 3));
            
            if (isDefending || game.isDefending) {
                dmg = Math.floor(dmg * 0.5);
                game.isDefending = false;
            }
            
            if (game.player.dmgReduction > 0) {
                dmg = Math.floor(dmg * (100 - Math.min(game.player.dmgReduction, 80)) / 100);
            }

            game.player.hp -= dmg;
            log(`💥 ${m.name} 攻击了你，造成 ${dmg} 点伤害！`, 'damage');
            updateUI();

            if (game.player.hp <= 0) {
                gameOver();
            }
        }

        function winCombat() {
            const m = game.currentMonster;
            log(`🎉 你击败了 ${m.name}！`, 'loot');

            const exp = m.isBoss ? 50 : 20;
            const stones = m.isBoss ? randomInt(8, 15) : randomInt(2, 6);
            game.player.stones += stones;
            
            addExp(exp);

            log(`📦 获得 ${exp} 经验，${stones} 个强化石`, 'loot');

            if (Math.random() < 0.6 || m.isBoss) {
                const item = generateEquipment();
                game.player.inventory.push(item);
                log(`🎁 获得装备：${item.name}`, 'loot');
            }

            if (m.isBoss) {
                game.floor++;
                log(`🏰 击败BOSS！进入第 ${game.floor} 层！`, 'loot');
            }

            updateUI();
            endCombat();
        }

        function endCombat() {
            game.state = 'idle';
            game.currentMonster = null;
            game.currentRoom = null;
            game.isDefending = false;

            ui.monsterPanel.classList.add('hidden');
            ui.combatButtons.classList.add('hidden');
