            ui.sceneDesc.textContent = '你打开了宝箱，现在可以继续探索...';
        }

        function enterEmptyRoom() {
            game.state = 'idle';
            game.currentRoom = null;
            
            const heal = Math.floor(game.player.maxHp * 0.25);
            game.player.hp = Math.min(game.player.maxHp, game.player.hp + heal);
            game.player.rage = Math.min(game.player.maxRage, game.player.rage + 30);

            log(`💤 进入安全房间，恢复了 ${heal} 点生命和30点怒气`, 'heal');
