        function generateEquipment(slot = null) {
            const slots = ['weapon', 'helmet', 'armor', 'legs', 'boots', 'ring', 'necklace'];
            const type = slot || slots[randomInt(0, slots.length - 1)];
            
            const rand = Math.random();
            let rarity;
            if (rand < 0.03) rarity = 'mythic';
            else if (rand < 0.10) rarity = 'legendary';
            else if (rand < 0.25) rarity = 'epic';
            else if (rand < 0.50) rarity = 'rare';
            else rarity = 'common';
            
            const cfg = rarityConfig[rarity];
            let name;
            let weaponType = null;
            let element = null;
            let skill = null;
            
            if (type === 'weapon') {
                const weaponTypes = Object.keys(equipmentNames.weapons);
                weaponType = weaponTypes[randomInt(0, weaponTypes.length - 1)];
                const weaponData = equipmentNames.weapons[weaponType];
                name = weaponData.names[randomInt(0, weaponData.names.length - 1)];
                element = weaponData.element;
                skill = weaponData.skill;
            } else {
                const names = equipmentNames[type === 'helmet' ? 'helmets' : type === 'armor' ? 'armors' : type === 'legs' ? 'legs' : type === 'boots' ? 'boots' : type === 'ring' ? 'rings' : 'necklaces'];
                name = names[randomInt(0, names.length - 1)];
            }
            
            const minEquipLevel = Math.max(1, game.floor - 3);
            const maxEquipLevel = game.floor + 3;
            const equipLevel = randomInt(minEquipLevel, maxEquipLevel);
            const equipLevelMultiplier = Math.pow(gameConfig.equip.levelMultiplier, equipLevel - 1);
            
            const item = {
                name: `${cfg.name}${name}`,
                type,
                rarity,
                equipLevel,
                upgradeLevel: 0,
                weaponType,
                element,
                skill,
                baseAtk: 0, baseDef: 0, baseHp: 0,
                atk: 0, def: 0, hp: 0,
                critRate: 0, critDmg: 0, dmgReduction: 0,
                fireDmg: 0, iceDmg: 0, thunderDmg: 0, shadowDmg: 0, holyDmg: 0,
                vampire: 0, attackSpeed: 0, dodge: 0,
                affixes: []
            };
            
            if (type === 'weapon') {
                item.baseAtk = Math.floor(game.floor * cfg.multiplier * 2);
            } else if (type === 'armor' || type === 'helmet' || type === 'legs') {
                item.baseDef = Math.floor(game.floor * cfg.multiplier * 1.5);
                item.baseHp = Math.floor(game.floor * cfg.multiplier * 3);
            } else if (type === 'boots') {
                item.baseDef = Math.floor(game.floor * cfg.multiplier * 0.8);
                item.dodge = Math.floor(game.floor * cfg.multiplier * 0.5);
            } else {
                item.baseHp = Math.floor(game.floor * cfg.multiplier * 2);
            }
            
            item.atk = Math.floor(item.baseAtk * equipLevelMultiplier);
            item.def = Math.floor(item.baseDef * equipLevelMultiplier);
            item.hp = Math.floor(item.baseHp * equipLevelMultiplier);
            
            const affixCount = randomInt(cfg.affixCount[0], cfg.affixCount[1]);
            const usedTypes = new Set();
            
            for (let i = 0; i < affixCount; i++) {
                let affix;
                do {
                    affix = affixTypes[randomInt(0, affixTypes.length - 1)];
                } while (usedTypes.has(affix.type));
                
                usedTypes.add(affix.type);
                const baseValue = affix.value(game.floor, cfg.multiplier);
                const value = Math.floor(baseValue * equipLevelMultiplier);
                item[affix.type] = (item[affix.type] || 0) + value;
                item.affixes.push({ type: affix.type, name: affix.name, value, color: affix.color });
            }
            
            return item;
        }

        function getAffixDisplay(item) {
            let html = '';
            
            if (item.type === 'weapon' && item.element) {
                const elementNames = { fire: '🔥 火焰', ice: '❄️ 冰霜', thunder: '⚡ 雷电', shadow: '🌑 暗影', holy: '✨ 神圣' };
                const elementColors = { fire: 'affix-fire', ice: 'affix-ice', thunder: 'affix-thunder', shadow: 'affix-shadow', holy: 'affix-holy' };
                html += `<div class="affix-row ${elementColors[item.element]}">伤害类型: ${elementNames[item.element]}</div>`;
            }

            let upgradeBonus = 0;
            for (let i = 1; i <= (item.upgradeLevel || 0); i++) {
                upgradeBonus += i;
            }
            const upgradeMultiplier = 1 + upgradeBonus / 100;
            const equipLevelMultiplier = Math.pow(gameConfig.equip.levelMultiplier, (item.equipLevel || 1) - 1);
            
            const stats = [
                { key: 'atk', name: '攻击', color: '', value: Math.floor((item.baseAtk || 0) * equipLevelMultiplier * upgradeMultiplier) },
                { key: 'def', name: '防御', color: '', value: Math.floor((item.baseDef || 0) * equipLevelMultiplier * upgradeMultiplier) },
                { key: 'hp', name: '生命', color: '', value: Math.floor((item.baseHp || 0) * equipLevelMultiplier * upgradeMultiplier) },
                { key: 'critRate', name: '暴击率', color: 'affix-crit', value: item.critRate || 0 },
                { key: 'critDmg', name: '暴击伤害', color: 'affix-crit', value: item.critDmg || 0 },
                { key: 'dmgReduction', name: '伤害减免', color: 'affix-reduction', value: item.dmgReduction || 0 },
                { key: 'fireDmg', name: '火焰伤害加成', color: 'affix-fire', isPercent: true, value: item.fireDmg || 0 },
                { key: 'iceDmg', name: '冰霜伤害加成', color: 'affix-ice', isPercent: true, value: item.iceDmg || 0 },
                { key: 'thunderDmg', name: '雷电伤害加成', color: 'affix-thunder', isPercent: true, value: item.thunderDmg || 0 },
                { key: 'shadowDmg', name: '暗影伤害加成', color: 'affix-shadow', isPercent: true, value: item.shadowDmg || 0 },
                { key: 'holyDmg', name: '神圣伤害加成', color: 'affix-holy', isPercent: true, value: item.holyDmg || 0 },
                { key: 'vampire', name: '吸血', color: 'affix-vampire', value: item.vampire || 0 },
                { key: 'dodge', name: '闪避', color: 'affix-dodge', value: item.dodge || 0 }
            ];
            
            stats.forEach(s => {
                if (s.value) {
                    const suffix = s.isPercent || s.key.includes('Rate') || s.key.includes('Reduction') || s.key === 'vampire' || s.key === 'dodge' ? '%' : '';
                    html += `<div class="affix-row ${s.color}">+${s.value}${suffix} ${s.name}</div>`;
                }
            });
            
            return html;
        }

        function showBag() {
            ui.bagList.innerHTML = '';

            if (game.player.inventory.length === 0) {
                ui.bagList.innerHTML = '<div style="color: #9ca3af; text-align: center;">背包是空的</div>';
            } else {
