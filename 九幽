                    const div = document.createElement('div');
                    div.className = 'item-row';
                    
                    let displayName = `（${item.equipLevel}级）${item.name}`;
                    if (item.upgradeLevel > 0) {
                        displayName += `+${item.upgradeLevel}`;
                    }
                    
                    div.innerHTML = `
                        <div style="flex: 1;">
                            <div class="rarity-${item.rarity}" style="font-weight: bold;">${displayName}</div>
                            <div style="margin-top: 5px;">${getAffixDisplay(item)}</div>
                        </div>
                        <div style="display: flex; gap: 5px; flex-direction: column;">
